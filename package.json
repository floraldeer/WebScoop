{
  "name": "webscoop",
  "version": "2.2.8",
  "description": "",
  "main": "./build-electron/index.js",
  "homepage": "./",
  "scripts": {
    "start": "concurrently \"cross-env BROWSER=none npm run start-web\"  \"wait-on http://localhost:3000 && npm run start-electron\" ",
    "start-debug": "concurrently \"cross-env BROWSER=none npm run start-web\"  \"wait-on http://localhost:3000 && npm run debug-electron\" ",
    "start-web": "react-app-rewired start",
    "start-electron": "webpack --config webpack.electron.js && electron .",
    "debug-electron": "webpack --config webpack.electron.js && electron --inspect --unhandled-rejections=strict --trace-deprecation .",
    "build-web": "cross-env GENERATE_SOURCEMAP=false react-app-rewired build",
    "build-electron": "webpack --config webpack.electron.js",
    "build-all": "rm -rf ./build && rm -rf ./build-electron && npm run build-electron && npm run build-web",
    "pack": "npm run build-all && electron-builder",
    "pack:win": "npm run build-all && electron-builder --win",
    "pack:mac": "rm -rf packs && npm run build-all && electron-builder --mac",
    "pack:all": "npm run build-all && electron-builder --win --mac",
    "gen-icon": "electron-icon-builder --input=./public/icon/icon.png --output=./public/icon",
    "pretty": "prettier --write \"src/**/*.{js,jsx,less}\" \"electron/**/*.js\"",
    "test": "cross-env CI=true react-app-rewired test --watchAll=false",
    "test:watch": "react-app-rewired test",
    "lint": "eslint \"src/**/*.{js,jsx}\" \"electron/**/*.js\"",
    "lint:fix": "eslint --fix \"src/**/*.{js,jsx}\" \"electron/**/*.js\"",
    "format:check": "prettier --check \"src/**/*.{js,jsx,less}\" \"electron/**/*.js\"",
    "prepare": "husky install"
  },
  "targets": {
    "electron": {
      "source": "electron/index.js",
      "context": "electron-main",
      "distDir": "build-electron"
    }
  },
  "lint-staged": {
    "src/**/*.{js,jsx,less}": "prettier --write",
    "electron/**/*.js": "prettier --write"
  },
  "devDependencies": {
    "concurrently": "^9.0.1",
    "cross-env": "^7.0.3",
    "customize-cra": "^1.0.0",
    "electron": "^26.1.0",
    "electron-builder": "^23.0.3",
    "electron-icon-builder": "^2.0.1",
    "eslint": "^8.57.1",
    "husky": "^8.0.1",
    "less": "^4.1.2",
    "less-loader": "^11.0.0",
    "lint-staged": "^15.5.2",
    "prettier": "^2.6.2",
    "react-app-rewired": "^2.2.1",
    "react-scripts": "5.0.1",
    "sharp": "^0.35.3",
    "wait-on": "^6.0.1",
    "webpack": "^5.72.1",
    "webpack-cli": "^4.9.2"
  },
  "dependencies": {
    "@ant-design/icons": "^4.7.0",
    "@xstate/react": "^3.0.0",
    "antd": "^4.20.5",
    "axios": "^0.27.2",
    "electron-is-dev": "^2.0.0",
    "electron-log": "^4.4.7",
    "electron-updater": "^6.8.9",
    "get-port": "^6.1.2",
    "hoxy": "^3.3.1",
    "lodash": "^4.17.21",
    "mkdirp": "^1.0.4",
    "pretty-bytes": "^6.0.0",
    "react": "^18.1.0",
    "react-dom": "^18.1.0",
    "regedit": "5.0.0",
    "semver": "^7.3.7",
    "sudo-prompt": "^9.2.1",
    "xstate": "^4.32.1",
    "youtube-dl-exec": "^3.1.9"
  },
  "author": "shlee",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/floraldeer/WebScoop.git"
  },
  "build": {
    "extends": null,
    "afterPack": "scripts/afterPack.js",
    "productName": "WebScoop",
    "appId": "com.lurich.WebScoop",
    "copyright": "Copyright © 2026 shlee",
    "directories": {
      "output": "packs"
    },
    "npmRebuild": false,
    "files": [
      "build/**/*",
      "build-electron/**/*",
      "public/**/*",
      "!node_modules/**/*",
      "!**/*.map",
      "!build/imgs/**",
      "!public/imgs/**"
    ],
    "mac": {
      "icon": "public/icon/icons/mac/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "public/plist/entitlements.mac.plist",
      "entitlementsInherit": "public/plist/entitlements.mac.plist",
      "target": {
        "target": "dmg",
        "arch": [
          "universal"
        ]
      }
    },
    "publish": {
      "provider": "github",
      "owner": "floraldeer",
      "repo": "WebScoop"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "ia32"
          ]
        }
      ],
      "icon": "public/icon/icons/win/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true
    },
    "extraResources": [
      {
        "from": "public",
        "to": "public",
        "filter": [
          "**/*",
          "!imgs/**"
        ]
      },
      {
        "from": "node_modules/youtube-dl-exec/bin",
        "to": "yt-dlp-bin"
      }
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
